classDiagram
  direction LR
  class Shipment {
    -id : int
    -tracking_number : String
    -order_id : int
    -user_id : int
    -carrier : String
    -service_type : String
    -status : String
    -recipient_name : String
    -recipient_phone : String
    -origin_address : JSON
    -destination_address : JSON
    -shipping_fee : Decimal
    -weight_kg : Decimal
    -estimated_delivery : DateTime
    -shipped_at : DateTime
    -delivered_at : DateTime
  }
  class ShipmentTracking {
    -id : int
    -status : String
    -location : String
    -description : Text
    -recorded_at : DateTime
  }
  Shipment "1" *-- "*" ShipmentTracking
