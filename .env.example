# ─── Database — MySQL (product, user, cart, ai_service) ──────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=changeme

# ─── Database — PostgreSQL (order, payment, shipping) ─────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ─── Cache ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Message broker ───────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── Security ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
INTERNAL_SERVICE_TOKEN=change-this-internal-token

# ─── Inter-service URLs (used by services calling each other) ─
PRODUCT_SERVICE_URL=http://product_service:8001
USER_SERVICE_URL=http://user_service:8002
CART_SERVICE_URL=http://cart_service:8003
ORDER_SERVICE_URL=http://order_service:8004
PAYMENT_SERVICE_URL=http://payment_service:8005
SHIPPING_SERVICE_URL=http://shipping_service:8006
AI_SERVICE_URL=http://ai_service:8007
RAG_SERVICE_URL=http://rag:8008

# ─── Graph DB ────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# ─── LLM ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── AI / RAG model settings ─────────────────────────────────
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
ACTIVE_MODEL=gru

# Hybrid retrieval weights (must sum to ~1.0)
LSTM_WEIGHT=0.4
GRAPH_WEIGHT=0.35
RAG_WEIGHT=0.25

# RAG-specific
FAISS_WEIGHT=0.6
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.25

# Recommendation result count
TOP_N=10
